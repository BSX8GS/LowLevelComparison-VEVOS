<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TextField?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="at.jku.simplelinedifference.Controller">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
  </padding>
  <GridPane hgap="10" vgap="10">
  <padding><Insets top="25" right="25" bottom="50" left="25"/></padding>

  <Label maxWidth="500" prefWidth="500" wrapText="true" text="Csv file containing the details of the PREVIOUS commit." GridPane.columnIndex="0" GridPane.rowIndex="0"
         GridPane.columnSpan="2"/>
  <TextField fx:id="tf_PreviousGT" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
  <Button text="Select File" onAction="#onSelectPrevFileButtonClick" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

  <Label maxWidth="500" prefWidth="500" wrapText="true" text="Csv file containing the details of the CURRENT commit." GridPane.columnIndex="0" GridPane.rowIndex="2"
         GridPane.columnSpan="2"/>
  <TextField fx:id="tf_CurrentGT" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
  <Button text="Select File" onAction="#onSelectCurrFileButtonClick" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
  </GridPane>
  <Button text="Run Comparison" onAction="#onRunComparison"/>
</VBox>
